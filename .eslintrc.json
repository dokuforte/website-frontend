{
  "extends": ["airbnb-base", "plugin:prettier/recommended"],
  "env": {
    "browser": true,
    "es6": true,
    "es2020": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "class-methods-use-this": "off",
    "no-param-reassign": [2, { "props": false }],
    "import/extensions": ["error", "ignorePackages", {
      "js": "always"
    }]
  }
}
